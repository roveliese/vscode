{
    "name":  "roseveil-theme",
    "publisher":  "xloiqa",
    "displayName":  "Roseveil Theme",
    "description":  "A soft dark VS Code theme with rose-tinted accents and cool contrast.",
    "version": "2.1.0",
    "engines":  {
                    "vscode":  "^1.70.0"
                },
    "categories":  [
                       "Themes"
                   ],
    "contributes":  {
                        "themes":  [
                                       {
                                           "label":  "Roseveil Dark",
                                           "uiTheme":  "vs-dark",
                                           "path":  "./themes/roseveil-dark.json"
                                       },
                                       {
                                           "label":  "Roseveil Light",
                                           "uiTheme":  "vs-light",
                                           "path":  "./themes/roseveil-light.json"
                                       }
                                   ]
                    },
    "icon":  "images/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/xloiqa/roseveil"
    },
    "scripts": {
        "build": "ts-node src/build.ts",
        "build:check": "tsc --noEmit",
        "verify": "ts-node src/verify.ts"
    },
    "devDependencies": {
        "typescript": "^5.0.0",
        "@types/node": "^20.0.0",
        "ts-node": "^10.9.0"
    }
}
