{
    "name": "roseveil-theme",
    "publisher": "xloiqa",
    "displayName": "Roseveil Theme",
    "description": "Atmospheric rose theme for VS Code",
    "version": "3.0.1",
    "engines": {
        "vscode": "^1.70.0"
    },
    "categories": [
        "Themes"
    ],
    "main": "./dist/extension.js",
    "activationEvents": [
        "onStartupFinished"
    ],
    "contributes": {
        "productIconThemes": [
            {
                "id": "roseveil-product-icons",
                "label": "Roseveil Product Icons",
                "path": "./producticons/roseveil-product-icon-theme.json"
            }
        ],
        "themes": [
            {
                "label": "Roseveil Dark",
                "uiTheme": "vs-dark",
                "path": "./themes/roseveil-dark.json"
            },
            {
                "label": "Roseveil Light",
                "uiTheme": "vs-light",
                "path": "./themes/roseveil-light.json"
            },
            {
                "label": "Roseveil Warm",
                "uiTheme": "vs-dark",
                "path": "./themes/roseveil-warm.json"
            },
            {
                "label": "Roseveil Storm",
                "uiTheme": "vs-dark",
                "path": "./themes/roseveil-storm.json"
            }
        ],
        "configuration": {
            "title": "Roseveil",
            "properties": {
                "roseveil.accentColor": {
                    "type": "string",
                    "default": "mauve",
                    "enum": [
                        "mauve",
                        "rose",
                        "lavender",
                        "sapphire",
                        "teal",
                        "sky"
                    ],
                    "description": "Primary accent color for badges, progress bar, and focus indicators."
                },
                "roseveil.italicKeywords": {
                    "type": "boolean",
                    "default": false,
                    "description": "Render keywords in italic."
                },
                "roseveil.boldKeywords": {
                    "type": "boolean",
                    "default": false,
                    "description": "Render keywords in bold."
                },
                "roseveil.italicComments": {
                    "type": "boolean",
                    "default": true,
                    "description": "Render comments in italic (on by default — matches Roseveil baseline)."
                },
                "roseveil.workbenchMode": {
                    "type": "string",
                    "default": "default",
                    "enum": [
                        "default",
                        "flat",
                        "minimal"
                    ],
                    "enumDescriptions": [
                        "Full three-shade chrome: sidebar, tabs, and editor have distinct backgrounds.",
                        "Reduced contrast: sidebar background matches the editor background.",
                        "Single-shade: sidebar, tabs, and panels all use the editor background."
                    ]
                },
                "roseveil.bracketColors": {
                    "type": "string",
                    "default": "monochromatic",
                    "enum": [
                        "monochromatic",
                        "dimmed",
                        "rainbow"
                    ],
                    "enumDescriptions": [
                        "All brackets use the foreground color (current default).",
                        "Brackets use progressively dimmed shades of the foreground.",
                        "Six distinct palette colors cycle across bracket depth levels."
                    ]
                }
            }
        }
    },
    "icon": "images/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/xloiqa/roseveil"
    },
    "scripts": {
        "build": "ts-node src/build.ts",
        "build:product-icons": "ts-node scripts/build-product-icons.ts",
        "build:check": "tsc --noEmit",
        "build:ext": "tsc -p tsconfig.ext.json",
        "verify": "ts-node src/verify.ts",
        "verify:all": "ts-node src/verify-all.ts",
        "verify:roles": "ts-node src/verify-roles.ts",
        "test": "node --require ts-node/register --test src/test/overrides.test.ts src/test/roles.test.ts"
    },
    "devDependencies": {
        "@tabler/icons": "^3.44.0",
        "@tabler/icons-webfont": "^3.44.0",
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.70.0",
        "fantasticon": "^4.1.0",
        "ts-node": "^10.9.0",
        "typescript": "^5.0.0"
    }
}
