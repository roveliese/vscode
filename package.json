{
    "name": "roveliese-vsc",
    "publisher": "Roveliese",
    "displayName": "Roveliese for VS Code",
    "description": "Atmospheric rose theme for VS Code",
    "version": "3.2.4",
    "engines": {
        "vscode": "^1.70.0"
    },
    "categories": [
        "Themes"
    ],
    "main": "./dist/extension.js",
    "activationEvents": [
        "onStartupFinished"
    ],
    "contributes": {
        "productIconThemes": [
            {
                "id": "roveliese-product-icons",
                "label": "Roveliese Product Icons",
                "path": "./producticons/roveliese-product-icon-theme.json"
            }
        ],
        "themes": [
            {
                "label": "Roveliese Dark",
                "uiTheme": "vs-dark",
                "path": "./themes/roveliese-dark.json"
            },
            {
                "label": "Roveliese Light",
                "uiTheme": "vs-light",
                "path": "./themes/roveliese-light.json"
            },
            {
                "label": "Roveliese Warm",
                "uiTheme": "vs-dark",
                "path": "./themes/roveliese-warm.json"
            },
            {
                "label": "Roveliese Storm",
                "uiTheme": "vs-dark",
                "path": "./themes/roveliese-storm.json"
            }
        ],
        "configuration": {
            "title": "Roveliese",
            "properties": {
                "roveliese.accentColor": {
                    "type": "string",
                    "default": "mauve",
                    "enum": [
                        "mauve",
                        "rose",
                        "lavender",
                        "sapphire",
                        "teal",
                        "sky"
                    ],
                    "description": "Primary accent color for badges, progress bar, and focus indicators."
                },
                "roveliese.italicKeywords": {
                    "type": "boolean",
                    "default": false,
                    "description": "Render keywords in italic."
                },
                "roveliese.boldKeywords": {
                    "type": "boolean",
                    "default": false,
                    "description": "Render keywords in bold."
                },
                "roveliese.italicComments": {
                    "type": "boolean",
                    "default": true,
                    "description": "Render comments in italic (on by default — matches Roveliese baseline)."
                },
                "roveliese.workbenchMode": {
                    "type": "string",
                    "default": "default",
                    "enum": [
                        "default",
                        "flat",
                        "minimal"
                    ],
                    "enumDescriptions": [
                        "Full three-shade chrome: sidebar, tabs, and editor have distinct backgrounds.",
                        "Reduced contrast: sidebar background matches the editor background.",
                        "Single-shade: sidebar, tabs, and panels all use the editor background."
                    ]
                },
                "roveliese.bracketColors": {
                    "type": "string",
                    "default": "monochromatic",
                    "enum": [
                        "monochromatic",
                        "dimmed",
                        "rainbow"
                    ],
                    "enumDescriptions": [
                        "All brackets use the foreground color (current default).",
                        "Brackets use progressively dimmed shades of the foreground.",
                        "Six distinct palette colors cycle across bracket depth levels."
                    ]
                }
            }
        }
    },
    "icon": "images/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/roveliese/vscode"
    },
    "scripts": {
        "build": "ts-node src/build.ts",
        "build:product-icons": "ts-node scripts/build-product-icons.ts",
        "build:check": "tsc --noEmit",
        "build:ext": "tsc -p tsconfig.ext.json",
        "check:all": "npm test && npm run build:check && npm run verify && npm run verify:all && npm run verify:roles",
        "release:prepare": "npm run build && npm run build:ext && npm run check:all",
        "verify": "ts-node src/verify.ts",
        "verify:all": "ts-node src/verify-all.ts",
        "verify:roles": "ts-node src/verify-roles.ts",
        "test": "node --require ts-node/register --test src/test/overrides.test.ts src/test/roles.test.ts"
    },
    "devDependencies": {
        "@tabler/icons": "^3.44.0",
        "@tabler/icons-webfont": "^3.44.0",
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.70.0",
        "fantasticon": "^4.1.0",
        "ts-node": "^10.9.0",
        "typescript": "^5.0.0"
    }
}
